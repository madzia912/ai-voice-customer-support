# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# ---- Storage ----
DATA_DIR=/data

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_JOB_QUEUE=voice.jobs
RABBITMQ_DLX=voice.jobs.dlx
RABBITMQ_DLQ=voice.jobs.dead
WORKER_PREFETCH=1

# ---- LLM ----
# One of: ollama | groq | huggingface
LLM_PROVIDER=ollama
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT=You are a concise, friendly customer support voice assistant. Answer in 1-3 sentences.

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# HuggingFace Inference API
HF_API_KEY=
HF_MODEL=meta-llama/Llama-3.2-1B-Instruct

# ---- TTS (ElevenLabs) ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# ---- Retry / HTTP ----
HTTP_TIMEOUT_SECONDS=60
RETRY_MAX_ATTEMPTS=4
RETRY_BACKOFF_BASE_SECONDS=1.0

# ---- Logging ----
LOG_LEVEL=INFO
